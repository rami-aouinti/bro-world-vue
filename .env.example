# --- Auth providers (privé) ---
NUXT_OAUTH_GITHUB_CLIENT_ID=""
NUXT_OAUTH_GITHUB_CLIENT_SECRET=""
NUXT_OAUTH_GOOGLE_CLIENT_ID=""
NUXT_OAUTH_GOOGLE_CLIENT_SECRET=""
NUXT_OAUTH_FACEBOOK_CLIENT_ID=""
NUXT_OAUTH_FACEBOOK_CLIENT_SECRET=""
NUXT_SESSION_PASSWORD=""

# --- AI Gateway (privé, serveur) ---
# Clé API utilisée côté serveur en prod/dev.
AI_GATEWAY_API_KEY=""
# Modèle par défaut si non défini: openai/gpt-4o-mini.
AI_GATEWAY_MODEL="openai/gpt-4o-mini"

# --- Football API (privé, serveur) ---
# URL de base de l'API football (défaut: https://v3.football.api-sports.io).
FOOTBALL_API_BASE_URL="https://v3.football.api-sports.io"
# Host envoyé dans les headers (défaut: v3.football.api-sports.io).
FOOTBALL_API_HOST="v3.football.api-sports.io"
FOOTBALL_API_KEY=""

# --- Basketball API (privé, serveur) ---
# URL de base de l'API basketball (défaut: https://v1.basketball.api-sports.io).
BASKETBALL_API_BASE_URL="https://v1.basketball.api-sports.io"
# Host envoyé dans les headers (défaut: v1.basketball.api-sports.io).
BASKETBALL_API_HOST="v1.basketball.api-sports.io"
# Optionnel: sinon FOOTBALL_API_KEY est utilisé (même secret API-SPORTS).
BASKETBALL_API_KEY=""

# --- SEO / Front public (public, exposé au client) ---
# URL canonique du site pour métadonnées/SEO (prod: domaine public; dev: URL locale).
# Défaut runtime: https://bro-world-space.com
NUXT_PUBLIC_SITE_URL="https://bro-world-space.com"
# Identifiant boutique global lu côté client (défaut: chaîne vide).
NUXT_PUBLIC_GLOBAL_SHOP_ID=""

GOOGLE_KEY_INDEX=""

# --- Paiement Stripe (privé, serveur) ---
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# --- Cache/stockage Nitro (privé, serveur) ---
# URL Redis pour activer le stockage partagé (recommandé en prod; optionnel en dev).
# Sans valeur, le fallback mémoire/local est utilisé.
REDIS_URL=""

# --- Prisma / Postgres (privé, serveur) ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bro_world"
